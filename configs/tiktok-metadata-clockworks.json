{
  "actor": "clockworks/tiktok-scraper",
  "purpose": "Primary TikTok creator metadata actor.",
  "input": {
    "profiles": [
      "mrbeast"
    ],
    "resultsPerPage": 5,
    "profileScrapeSections": [
      "videos"
    ],
    "profileSorting": "latest",
    "oldestPostDateUnified": "365 days",
