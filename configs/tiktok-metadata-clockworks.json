    "shouldDownloadVideos": false,
    "shouldDownloadCovers": false,
    "shouldDownloadSlideshowImages": false,
    "shouldDownloadAvatars": false,
    "shouldDownloadMusicCovers": false,
    "commentsPerPost": 0,
    "downloadSubtitlesOptions": "NEVER_DOWNLOAD_SUBTITLES"
  },
  "notes": [
    "Apify page lists pricing from $1.70 per 1,000 results.",
    "Verified on a public TikTok profile with caption text, webVideoUrl, createTimeISO, playCount, diggCount, commentCount, and shareCount."
  ]
}
